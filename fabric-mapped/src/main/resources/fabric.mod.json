{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",
  "name": "${name}",
  "icon": "${id}.png",
  "description": "${description}",
  "authors": [
    "${author}"
  ],
  "contact": {
    "sources": "https://codeberg.org/stonecutter/template-fabric"
  },
  "license": "${license}",
  "environment": "client",
  "entrypoints": {
    "client": [
      "foundry.imgui.fabric.impl.ImGuiMCFabric"
    ]
  },
  "mixins": [
    "${id}.mixins.json",
    "${id}.fabric.mixins.json"
  ],
  "depends": {
    "fabric-api-base": "*",
    "fabricloader": ">=0.17",
    "minecraft": "${minecraft}",
    "java": ">=${java}"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.discord": "https://discord.gg/2aqTX9QWKU",
        "modmenu.modrinth": "https://modrinth.com/mod/imguimc",
        "modmenu.curseforge": "https://curseforge.com/minecraft/mc-mods/imguimc"
      },
      "badges": [ "library" ]
    }
  }
}


